#!/bin/bash

BATTERY=/sys/class/power_supply/BAT0

case "$(cat $BATTERY/status)" in
	"Full")		STATUS="´ëÇ";;
	"Discharging")	STATUS="´ëä";;
	"Charging")	STATUS="´çª";;
	"Not charging")	STATUS="´Çì";;
	"Unknown")	STATUS="´ü¬";;
	*) exit 1 ;;
esac

PERCENT=$(cat "$BATTERY/capacity" 2>&1)

case $BLOCK_BUTTON in
	1) dmenu-system ;;
	4) brightnessctl -q s +5% ;;
	5) brightnessctl -q s 5%- ;;
esac

echo "$STATUS $PERCENT%"

